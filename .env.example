# ════════════════════════════════════════════════
#  POS System — Variables de entorno por entorno
#  Copia este archivo como .env y edita los valores
# ════════════════════════════════════════════════

# ── Base de datos ───────────────────────────────
# LOCALHOST (docker-compose):
DATABASE_URL=postgresql://posuser:pospass123@localhost:5432/posdb

# VPS / Producción — descomentar y ajustar:
# DATABASE_URL=postgresql://tu_usuario:tu_password@localhost:5432/tu_db

# Render QA — usar la Internal Database URL del dashboard

# ── MinIO / Almacenamiento de imágenes ──────────
# LOCALHOST:
MINIO_URL=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# VPS / Producción — la URL pública debe ser accesible desde el navegador:
# MINIO_URL=http://localhost:9000
# MINIO_PUBLIC_URL=http://tudominio.com:9000
# MINIO_ACCESS_KEY=tu_access_key_segura
# MINIO_SECRET_KEY=tu_secret_key_segura

# ── Seguridad ───────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
