# ════════════════════════════════════════════════════════
#  POS System — Variables de entorno
#  Copia como .env y edita los valores según tu entorno
#  NUNCA subas el .env real a GitHub
# ════════════════════════════════════════════════════════

# ── Base de datos ────────────────────────────────────────
POSTGRES_DB=posdb
POSTGRES_USER=posuser
POSTGRES_PASSWORD=cambia-este-password-en-produccion

# ── MinIO ────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=cambia-este-password-en-produccion
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=cambia-este-password-en-produccion

# URL interna (docker-compose usa http://minio:9000 automáticamente)
# URL pública — la que el navegador del cliente usa para ver las imágenes:
#   Localhost:   http://localhost:9000
#   VPS:         http://tudominio.com:9000  o  https://storage.tudominio.com
#   Render QA:   no aplica (MinIO no disponible en plan free)
MINIO_PUBLIC_URL=http://localhost:9000

# ── Seguridad JWT ────────────────────────────────────────
# Genera una clave aleatoria segura con:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria-de-64-caracteres

# ── CORS — dominios permitidos ───────────────────────────
# Localhost:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Render QA — agregar tu URL del frontend:
# ALLOWED_ORIGINS=http://localhost:3000,https://pos-system-frontend.onrender.com
# Producción VPS:
# ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ── Endpoint de emergencia ───────────────────────────────
# Genera una clave aleatoria:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
# Para usar el endpoint:
#   curl -X POST https://tu-backend.com/api/reset-users-emergency \
#        -H "X-Emergency-Key: tu-clave-aqui"
EMERGENCY_KEY=cambia-esto-por-una-clave-aleatoria
